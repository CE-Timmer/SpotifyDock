{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Spotify Lyrics Overlay",
  "version": "0.1.0",
  "identifier": "com.chris.spotifylyricsoverlay",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "control",
        "title": "SpotifyDock",
        "width": 520,
        "height": 360,
        "minWidth": 460,
        "minHeight": 320,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "skipTaskbar": false,
        "alwaysOnTop": false,
        "visible": true,
        "focus": true
      },
      {
        "label": "main",
        "title": "Spotify Lyrics Overlay",
        "width": 800,
        "height": 120,
        "minWidth": 800,
        "minHeight": 120,
        "maxHeight": 120,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": true,
        "focus": false
      },
      {
        "label": "hover-zone",
        "title": "Spotify Hover Zone",
        "width": 800,
        "height": 10,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": true,
        "focus": false
      },
      {
        "label": "auth-popup",
        "title": "Connect Spotify",
        "width": 430,
        "height": 190,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "skipTaskbar": false,
        "alwaysOnTop": false,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
